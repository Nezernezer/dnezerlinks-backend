{
  "rules": {
    // Keep your Master Admin Key
    ".read": "auth.uid === 'VCSNLSzYV2WsNG93mPE2ZtwdTna2'",
    ".write": "auth.uid === 'VCSNLSzYV2WsNG93mPE2ZtwdTna2'",

    "users": {
      // Allow searching by email index
      ".indexOn": ["email"],
      
      // This allows your Render Server (Admin SDK) to write 
      // the account_number to any email-based node
      "$user_identifier": {
        ".read": "auth != null", 
        ".write": "auth != null"
      }
    },
    
    "transactions": {
      "$uid": {
        ".read": "auth.uid === $uid",
        ".write": "auth.uid === $uid"
      }
    },
    "settings": {
      ".read": "true",
      ".write": "auth.uid === 'VCSNLSzYV2WsNG93mPE2ZtwdTna2'"
    }
  }
}
